<div class="container d-flex justify-content-center align-items-center" style="height: 60vh;">
  <div class="card text-center shadow p-5" style="max-width: 500px; background: rgba(255, 255, 255, 0.95); border: none;">
    
    <div class="mb-4">
      <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
    </div>

    <h2 class="mb-3">Welcome Aboard!</h2>
    <p class="lead text-muted mb-4">
      Your crew assignment has been confirmed. You have been added to the ship's manifest.
    </p>

    <div class="d-grid gap-2">
      <%= link_to root_path, class: "btn btn-primary btn-lg" do %>
        <i class="bi bi-grid-3x3-gap-fill"></i> Return to Desktop
      <% end %>
    </div>

  </div>
</div>